# Bow env variables (copy to .env.local for Next.js, .env for scripts)

# ====== Server-side (cron + scripts) ======
# AI operator private key. Must own the HybridVault. Treat as production
# secret; never commit. The deploy script also reads PRIVATE_KEY.
PRIVATE_KEY=0x...

# Anthropic API key for Claude Haiku 4.5. If missing, agent-loop falls
# back to a deterministic heuristic.
ANTHROPIC_API_KEY=sk-ant-...

# ====== Contract addresses on Arc testnet ======
BOW_VAULT=0x87107f7122FD12cB15740DfA292FffB0d7f180B2
BOW_DECISION_LOG=0xf547A123859C868fC42d720251B1DBdb59d2e5c9
BOW_TOURNAMENT=0xc64F830e8a38f9253649D318589c82a9A3b486CE

# ====== Optional ======
# Arcscan API key (post-mainnet release)
ARCSCAN_API_KEY=
